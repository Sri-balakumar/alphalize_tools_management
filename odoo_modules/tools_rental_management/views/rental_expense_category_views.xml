<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ═══ LIST VIEW ═══ -->
    <record id="view_rental_expense_category_tree" model="ir.ui.view">
        <field name="name">rental.expense.category.tree</field>
        <field name="model">rental.expense.category</field>
        <field name="arch" type="xml">
            <list string="Expense Categories">
                <field name="name"/>
                <field name="code" string="Reference"/>
                <field name="guideline" string="Note"/>
                <field name="cost" sum="Total Cost"/>
                <field name="tax_percent" string="Tax %"/>
                <field name="currency_id" column_invisible="1"/>
                <field name="active" widget="boolean_toggle" optional="hide"/>
            </list>
        </field>
    </record>

    <!-- ═══ FORM VIEW ═══ -->
    <record id="view_rental_expense_category_form" model="ir.ui.view">
        <field name="name">rental.expense.category.form</field>
        <field name="model">rental.expense.category</field>
        <field name="arch" type="xml">
            <form string="Expense Category">
                <sheet>
                    <field name="image" widget="image" class="oe_avatar"
                           options="{'preview_image': 'image'}"/>
                    <div class="oe_title">
                        <label for="name" string="Category Name"/>
                        <h1>
                            <field name="name" placeholder="e.g. Communication"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="code" placeholder="e.g. COMM"/>
                            <field name="cost"/>
                            <field name="tax_percent"/>
                            <field name="currency_id" invisible="1"/>
                        </group>
                        <group>
                            <field name="company_id"
                                   groups="base.group_multi_company"/>
                            <field name="active"/>
                        </group>
                    </group>
                    <separator string="Guideline"/>
                    <field name="guideline"
                           placeholder="When should users pick this category? e.g. Phone bills, postage, etc."/>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ═══ SEARCH VIEW ═══ -->
    <record id="view_rental_expense_category_search" model="ir.ui.view">
        <field name="name">rental.expense.category.search</field>
        <field name="model">rental.expense.category</field>
        <field name="arch" type="xml">
            <search string="Search Expense Categories">
                <field name="name"/>
                <field name="code"/>
                <separator/>
                <filter string="Active" name="active"
                        domain="[('active', '=', True)]"/>
                <filter string="Archived" name="inactive"
                        domain="[('active', '=', False)]"/>
            </search>
        </field>
    </record>

    <!-- ═══ ACTION ═══ -->
    <record id="action_rental_expense_category" model="ir.actions.act_window">
        <field name="name">Expense Categories</field>
        <field name="res_model">rental.expense.category</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_rental_expense_category_search"/>
        <field name="context">{'search_default_active': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first expense category
            </p>
            <p>
                Each category carries a default Cost and Tax % which will
                auto-fill on the expense form when picked.
            </p>
        </field>
    </record>

</odoo>
